# Copy this file to .env and fill in your values
# Never commit .env to git

# Your Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Your Azure App Insights App ID
# Run: az resource show --name YOUR_APP_NAME --resource-type microsoft.insights/components --query properties.AppId
APPINSIGHTS_APP_ID=your-app-insights-app-id-here

# Monitoring interval in minutes (default 60)
MONITOR_INTERVAL_MINUTES=60
